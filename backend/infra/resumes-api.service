[Unit]
Description=Resumes API
After=network.target

[Service]
WorkingDirectory=%h/blueressearch/backend
EnvironmentFile=%h/blueressearch/backend/deployments/resumes/.env
ExecStart=%h/blueressearch/backend/.venv/bin/uvicorn deployments.resumes.main_sentence_transformers:app --host 127.0.0.1 --port 8002
Restart=on-failure

[Install]
WantedBy=default.target
